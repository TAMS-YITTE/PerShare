# PerShare V1 — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ATTENTION : Ne jamais commiter .env sur GitHub

# Cle privee du wallet de deploiement
PRIVATE_KEY=votre_cle_privee_ici

# API Key BscScan pour la verification du contrat
BSCSCAN_API_KEY=votre_api_key_bscscan

# Adresses apres deploiement BNB Testnet
PERSHARE_TESTNET=
USDT_TESTNET=
PRESALE_TOKEN_TESTNET=

# Adresses apres deploiement BNB Mainnet
PERSHARE_MAINNET=

# Adresses stablecoins BNB Mainnet (ne pas modifier)
USDT_MAINNET=0x55d398326f99059fF775485246999027B3197955
USDC_MAINNET=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
